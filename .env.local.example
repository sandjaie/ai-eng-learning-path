# --- Production / cloud Supabase (Vercel + Google OAuth) ---
# Copy to .env.local when pointing the app at your hosted project.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY
# Only this Google account may use the app in production
ALLOWED_EMAIL=you@example.com

# --- Local development ---
# Prefer: ./scripts/dev.sh (or npm run dev:local) with Colima.
# Starts Colima + local Supabase; seed.sql creates you@example.com /
# local-dev-password and sample data. Script exports local URL/keys plus:
#   ALLOWED_EMAIL=you@example.com
#   DEV_AUTO_LOGIN=true
#   DEV_LOGIN_PASSWORD=local-dev-password
# DEV_* is ignored unless NODE_ENV=development (never set these on Vercel).
# DEV_AUTO_LOGIN=true
# DEV_LOGIN_PASSWORD=local-dev-password
